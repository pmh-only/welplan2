# Webapp runtime template (copy to .env)
# Required only for Welstory fetches; PlanEAT requires no credentials.
WELSTORY_USERNAME=your_welstory_id
WELSTORY_PASSWORD=your_welstory_password
# WELSTORY_DEVICE_ID=optional-device-id

# Optional cache TTL override (ms) for menu cache freshness checks
# MENU_CACHE_TTL_MS=1800000

# Logging flags (set to 1/true/yes/on to enable)
WELPLAN_VERBOSE_LOGS=off
WELPLAN_SYNC_LOGS=off
WELPLAN_TRAFFIC_LOGS=off
WELPLAN_AUTH_LOGS=off

# Server settings
HOST=0.0.0.0
PORT=3000

# Prefer DATABASE_URL or fall back to PG* values
# DATABASE_URL=postgresql://welplan2_user:replace-me@localhost:5432/welplan2
PGHOST=localhost
PGPORT=5432
PGDATABASE=welplan2
PGUSER=welplan2_user
PGPASSWORD=replace-me

# Optional DB aliases kept for compatibility
# DB_HOST=localhost
# DB_NAME=welplan2
# DB_USER=welplan2_user
# DB_PASSWORD=replace-me

# Use a custom env location if needed
# DOTENV_PATH=/path/to/custom.env
