# Webapp runtime template (copy to .env)
# Required only for Welstory fetches; PlanEAT requires no credentials.
WELSTORY_USERNAME=your_welstory_id
WELSTORY_PASSWORD=your_welstory_password
# WELSTORY_DEVICE_ID=optional-device-id

# Optional cache TTL override (ms) for menu cache freshness checks
# MENU_CACHE_TTL_MS=1800000

# Redis read-through cache layered on top of PostgreSQL
REDIS_URL=redis://127.0.0.1:6379
REDIS_CACHE_PREFIX=welplan2:
REDIS_CACHE_DISABLED=off

# Logging flags (set to 1/true/yes/on to enable)
WELPLAN_VERBOSE_LOGS=off
WELPLAN_SYNC_LOGS=off
WELPLAN_TRAFFIC_LOGS=off
WELPLAN_AUTH_LOGS=off

# Admin OIDC authentication for /admin
# ADMIN_OIDC_ISSUER_URL=https://login.example.com/realms/welplan
# Optional when discovery URL differs from issuer + /.well-known/openid-configuration
# ADMIN_OIDC_DISCOVERY_URL=https://login.example.com/custom/.well-known/openid-configuration
# ADMIN_OIDC_CLIENT_ID=welplan-admin
# ADMIN_OIDC_CLIENT_SECRET=replace-me
# Defaults to <request-origin>/admin/callback when unset
# ADMIN_OIDC_REDIRECT_URI=https://welplan.example.com/admin/callback
# ADMIN_OIDC_SCOPES=openid profile email
# Defaults to query to avoid cross-site OIDC form_post callbacks
# ADMIN_OIDC_RESPONSE_MODE=query

# Server settings
HOST=0.0.0.0
PORT=3000
# Public origin used by SvelteKit's CSRF checks and absolute URL generation behind a proxy
ORIGIN=https://welplan.example.com
# Alternative to ORIGIN when the reverse proxy forwards host/protocol headers
# HOST_HEADER=x-forwarded-host
# PROTOCOL_HEADER=x-forwarded-proto

# Prefer DATABASE_URL or fall back to PG* values
# DATABASE_URL=postgresql://welplan2_user:replace-me@localhost:5432/welplan2
PGHOST=localhost
PGPORT=5432
PGDATABASE=welplan2
PGUSER=welplan2_user
PGPASSWORD=replace-me

# Optional DB aliases kept for compatibility
# DB_HOST=localhost
# DB_NAME=welplan2
# DB_USER=welplan2_user
# DB_PASSWORD=replace-me

# Use a custom env location if needed
# DOTENV_PATH=/path/to/custom.env
