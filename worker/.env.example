# Worker runtime template (copy to .env)
# Worker runs the background prefetcher and writes to the shared cache DB.

# Credentials for remote vendor requests
WELSTORY_USERNAME=your_welstory_id
WELSTORY_PASSWORD=your_welstory_password
# WELSTORY_DEVICE_ID=optional-device-id

# Polling schedule controls
WORKER_ACTIVE_PREFETCH_INTERVAL_MS=600000
WORKER_FULL_SCAN_INTERVAL_MS=21600000
WORKER_ACTIVE_PREFETCH_DAYS=2

# Redis read-through cache layered on top of PostgreSQL
REDIS_URL=redis://127.0.0.1:6379
REDIS_CACHE_PREFIX=welplan2:
REDIS_CACHE_DISABLED=off

# Logging flags (set to 1/true/yes/on to enable)
WELPLAN_VERBOSE_LOGS=off
WELPLAN_SYNC_LOGS=off
WELPLAN_TRAFFIC_LOGS=off
WELPLAN_AUTH_LOGS=off

# Shared PostgreSQL cache backend
# DATABASE_URL=postgresql://welplan2_user:replace-me@localhost:5432/welplan2
PGHOST=localhost
PGPORT=5432
PGDATABASE=welplan2
PGUSER=welplan2_user
PGPASSWORD=replace-me

# Optional DB aliases kept for compatibility
# DB_HOST=localhost
# DB_NAME=welplan2
# DB_USER=welplan2_user
# DB_PASSWORD=replace-me

# Use a custom env location if needed
# DOTENV_PATH=/path/to/custom.env
